# Local Postgres (docker-compose.yml)
DB_USER=""
DB_PASSWORD=""
DB_NAME=""

# Full connection string consumed by src/data/env/server.ts and drizzle.config.ts
DATABASE_URL=""

# Inngest — dev-mode flag, tells the SDK not to expect a signing key locally.
# Leave unset (or set INNGEST_SIGNING_KEY/INNGEST_EVENT_KEY instead) in prod.
INNGEST_DEV=1

# Dormant until Phase 2 (sessions/ratelimit) — leave blank for now.
REDIS_URL=""
REDIS_TOKEN=""

# Dormant until Phase 4 (media upload) — leave blank for now.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_STORAGE_BUCKET=""
