# Local Postgres (docker-compose.yml)
DB_USER=""
DB_PASSWORD=""
DB_NAME=""

# Full connection string consumed by src/data/env/server.ts and drizzle.config.ts
DATABASE_URL=""

# Inngest — dev-mode flag, disables signature verification so the SDK doesn't
# expect a signing key locally. Set to 1 ONLY in your local .env, never in a
# deployed environment — set INNGEST_SIGNING_KEY/INNGEST_EVENT_KEY there instead.
INNGEST_DEV=""

# Dormant until Phase 2 (sessions/ratelimit) — leave blank for now.
REDIS_URL=""
REDIS_TOKEN=""

# Used to build absolute links (email verification, OAuth redirect).
# Defaults to http://localhost:3000 if unset.
BASE_URL=""

# Dormant until Mohamed provides Google OAuth credentials (Phase 2).
OAUTH_REDIRECT_URL_BASE=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Dormant until Mohamed provides SMTP credentials (Phase 2) — leave blank for
# now, sendMail logs a warning and no-ops instead of throwing.
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""
SMTP_FROM_NAME=""

# Dormant until Phase 4 (media upload) — leave blank for now.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_STORAGE_BUCKET=""
